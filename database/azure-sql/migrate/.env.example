# Supabase API (required) — Project URL from Settings → API, NOT the database host
SUPABASE_URL=https://oyldgeairjcetcavibun.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: direct Postgres for auth.users password hashes
# Do NOT use https://... or db.[ref].supabase.co unless it resolves in your project.
# Use Session pooler URI from: Settings → Database → Connection string → URI
# Example (replace [password] and region):
# SUPABASE_DB_URL=postgresql://postgres.oyldgeairjcetcavibun:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Azure SQL (target)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=hainan
# Azure SQL login — use SQL username/password (not Azure AD)
AZURE_SQL_USER=sqladmin
AZURE_SQL_PASSWORD=your-password
# AZURE_SQL_USE_AAD is not used by the migrate script yet (placeholder for future).
# Leave unset; keep using AZURE_SQL_USER + AZURE_SQL_PASSWORD above.

# Migration options
BATCH_SIZE=100
FETCH_RETRIES=3
FETCH_TIMEOUT_MS=60000
# Set to 1 to truncate target tables before import (destructive)
TRUNCATE_BEFORE_IMPORT=0

# Azure Blob — use double quotes (value contains = and ;)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net"
# Container name is fixed in script: study-loan-documents (same as Supabase bucket; created automatically)
